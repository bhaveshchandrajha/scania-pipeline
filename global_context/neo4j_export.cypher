// Neo4j export generated from global_context artifacts
// Load this file in the Neo4j browser or Cypher shell;
// lines starting with '// params' show suggested parameter maps.

MERGE (f:DbFile {name: $name, library: $library}) ON CREATE SET f.symbolId = $symbol_id ON MATCH SET  f.symbolId = coalesce(f.symbolId, $symbol_id);
// params {"name": "AUFWKO", "library": "HSSRC", "symbol_id": "sym.file.AUFWKO"}
MERGE (c:Column {name: $name, sqlType: $sqlType, length: $length, scale: $scale}) ON CREATE SET c.key = $key ON MATCH SET  c.key = coalesce(c.key, $key);
// params {"name": "WKO010", "sqlType": "CHAR(3)", "length": 3, "scale": null, "key": false}
MATCH (f:DbFile {name: $name, library: $library}),       (c:Column {name: $col_name}) MERGE (f)-[:HAS_COLUMN]->(c);
// params {"name": "AUFWKO", "library": "HSSRC", "col_name": "WKO010"}
MERGE (c:Column {name: $name, sqlType: $sqlType, length: $length, scale: $scale}) ON CREATE SET c.key = $key ON MATCH SET  c.key = coalesce(c.key, $key);
// params {"name": "WKO020", "sqlType": "CHAR(5)", "length": 5, "scale": null, "key": true}
