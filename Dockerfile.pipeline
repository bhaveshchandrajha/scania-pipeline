# Migration Pipeline – Full stack for local examination & UAT
# Build: docker build -f Dockerfile.pipeline -t migration-pipeline:1.0 .
# Run:   docker run -p 8003:8003 -p 8081:8081 -v $(pwd):/workspace -e ANTHROPIC_API_KEY=xxx migration-pipeline:1.0

FROM python:3.11-slim-bookworm AS base

# Install Node.js 20, Maven, Java 17, Git (for push_to_repo, push_test_results)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gnupg \
    ca-certificates \
    git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && curl -fsSL https://archive.apache.org/dist/maven/maven-3/3.9.6/binaries/apache-maven-3.9.6-bin.tar.gz | tar xz -C /opt \
    && ln -sf /opt/apache-maven-3.9.6/bin/mvn /usr/local/bin/mvn \
    && apt-get install -y --no-install-recommends openjdk-17-jdk \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Python deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy pipeline (scripts, UI, warranty_demo, warranty-ui)
COPY . .

# Expose ports
ENV UI_PORT=8003
EXPOSE 8003 8081

# Start Pipeline UI
CMD ["python3", "ui_global_context_server.py"]
