# Copy to .env on the server and fill in. Never commit .env.
#
# Required for LLM migration / build steps:
ANTHROPIC_API_KEY=
#
# Optional — Push to another repo from the pipeline UI (EC2/Docker has no Keychain; set one of these):
# GIT_PUSH_TOKEN=ghp_...          # preferred name (same as GitHub Actions secret GIT_PUSH_TOKEN)
# GITHUB_TOKEN=ghp_...            # alternative
# GITHUB_TOKEN_FILE=/path/to/file   # first line = PAT (Docker/K8s secrets)
# GIT_USE_TOKEN=0                 # set only to disable embedding PAT (use SSH remote instead)
#
# Optional overrides (defaults are fine for EC2 Docker):
# UI_PORT=8003
# APP_PORT=8082
# SPRING_INTERNAL_PORT=8081
# BIND_HOST=0.0.0.0
# RUN_PROFILE=rds
# SKIP_TESTS=0
# GIT_USER_EMAIL=
# GIT_USER_NAME=
