# Copy to .env on the server and fill in. Never commit .env.
#
# Required for LLM migration / build steps:
ANTHROPIC_API_KEY=
#
# Optional — Push to GitHub from the pipeline UI:
# GITHUB_TOKEN=
# GIT_USE_TOKEN=1
#
# Optional overrides (defaults are fine for EC2 Docker):
# UI_PORT=8003
# APP_PORT=8082
# SPRING_INTERNAL_PORT=8081
# BIND_HOST=0.0.0.0
# RUN_PROFILE=rds
# SKIP_TESTS=0
# GIT_USER_EMAIL=
# GIT_USER_NAME=
